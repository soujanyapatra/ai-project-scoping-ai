# LLM Engine Configuration
# Set your API key here. If empty/unset, the backend will fall back to simulated streaming.
LLM_API_KEY=

# LLM Model selection. Can be any provider/model name.
LLM_MODEL=openrouter/free

# Base URL for the LLM API endpoint (e.g. OpenAI, OpenRouter, DeepSeek, local LM Studio, etc.)
LLM_API_BASE=https://openrouter.ai/api/v1

# FastAPI Configuration
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=9000
